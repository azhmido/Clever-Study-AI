rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Study Material Validation ---
    function isValidStudyMaterial(data) {
      return data.keys().hasAny(['userId', 'title', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 300 &&
             data.createdAt is number;
    }

    match /studyMaterials/{materialId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() &&
                    isValidId(materialId) &&
                    isValidStudyMaterial(incoming());
      allow update: if isSignedIn() &&
                    existing().userId == request.auth.uid &&
                    isValidStudyMaterial(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- Quiz Attempt Validation ---
    function isValidQuizAttempt(data) {
      return data.keys().hasAll(['userId', 'materialId', 'score', 'totalQuestions', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.materialId is string && data.materialId.size() <= 128 &&
             data.score is number && data.score >= 0 &&
             data.totalQuestions is number && data.totalQuestions > 0 &&
             data.createdAt is number;
    }

    match /quizAttempts/{attemptId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() &&
                    isValidId(attemptId) &&
                    isValidQuizAttempt(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
