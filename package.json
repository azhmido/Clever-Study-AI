    "firebase-admin": "^13.10.0",
    "formidable": "^3.5.4",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.23.24",
    "officeparser": "^7.0.3",
    "pdf-parse": "^2.4.5",
    "pdf2json": "^4.0.3",
    "react": "^19.0.1",
